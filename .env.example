# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# --- Database ---
# Production (Railway): add PostgreSQL plugin — DATABASE_URL is set automatically.
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Optional: disable SSL for local PostgreSQL (default: require SSL for cloud DBs)
# DATABASE_SSL=0

# Local dev without Postgres: SQLite file (ignored when DATABASE_URL is set)
# DATABASE_PATH=./data/events.db

# Optional: Webhook URL (if using webhooks instead of polling)
# WEBHOOK_URL=https://your-domain.com/webhook
