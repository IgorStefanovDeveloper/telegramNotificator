# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# PostgreSQL (required). Railway: add Postgres plugin → DATABASE_URL is set automatically.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: disable SSL for local PostgreSQL (default: require SSL for cloud DBs)
# DATABASE_SSL=0

# Tests: use a separate DB so you never wipe production (overrides DATABASE_URL during pytest)
# TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/telegram_bot_test

# Optional: Webhook URL (if using webhooks instead of polling)
# WEBHOOK_URL=https://your-domain.com/webhook
